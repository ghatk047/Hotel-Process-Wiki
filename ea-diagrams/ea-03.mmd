    SYNXIS3["SynXis CRS\nRate loading · Availability control · Restrictions"]
    MARSHA2["MARSHA\nMarriott brand reservations"]
    SYNXIS3 -->|"confirmed bookings"| MARSHA2
  end

  subgraph CHANNELS["📡 Distribution Channels"]
    direction LR
    OTA2["OTA Channel Manager\nSiteMinder · Booking.com · Expedia"]
    GDS2["GDS Connectivity\nAmadeus · Sabre · Travelport"]
    DIRECT2["Marriott.com\nBest Rate Guarantee · Member rates"]
    WHOLESALE["Wholesale\nTour operators · Bedbanks"]
    CORPORATE["Corporate Rates\nNegotiated · LNR · GNE"]
  end

  subgraph MONITOR["📈 Rate Parity & Performance"]
    direction LR
    PARITY["Rate Parity Monitor\nRateGain · OTA Insight"]
    POWERBI3["Power BI\nRevPAR · ADR · Occ · GOPPAR"]
    STR["STR Report\nCompset benchmarking"]
  end

  OPERA_PICKUP  -->|"demand data"| IDEAS2
  RATEGAIN2     -->|"competitor intel"| IDEAS2
  BONVOY_DEMAND -->|"segment demand"| IDEAS2
  EVENTS        -->|"event demand"| IDEAS2
  WEATHER       -->|"seasonality"| DUETTO
  OPERA_PICKUP  -->|"group queries"| DUETTO

  REVMGR -->|"approved rates"| SYNXIS3

  SYNXIS3 -->|"rate push"| OTA2
  SYNXIS3 -->|"rate · availability"| GDS2
  SYNXIS3 -->|"BAR · packages"| DIRECT2
  SYNXIS3 -->|"allotment rates"| WHOLESALE
  SYNXIS3 -->|"negotiated rates"| CORPORATE

  OTA2     -->|"bookings"| MARSHA2
  GDS2     -->|"bookings"| MARSHA2
  DIRECT2  -->|"bookings"| MARSHA2
  MARSHA2  -->|"reservations"| OPERA_PICKUP

  OTA2    -->|"rate parity check"| PARITY
  DIRECT2 -->|"live rates"| PARITY
  PARITY  -->|"parity alerts"| REVMGR
  MARSHA2 -->|"revenue data"| POWERBI3
  STR     -->|"compset index"| POWERBI3
  POWERBI3-->|"performance KPIs"| REVMGR

