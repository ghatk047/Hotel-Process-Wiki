flowchart TB

  subgraph SIGNALS["📊 Demand Signal Inputs"]
    direction LR
    OPERA_PICKUP["OPERA PMS\nPickup · Pace · OTB data"]
    RATEGAIN2["RateGain\nCompetitor rates · OTA pricing"]
    BONVOY_DEMAND["Bonvoy CRM\nLoyalty demand · segment data"]
    EVENTS["Events Calendar\nConventions · Citywide events"]
    WEATHER["Weather · Seasonality\nExternal demand drivers"]
  end

  subgraph RMS["🧠 Revenue Management Engine"]
    direction LR
    IDEAS2["IDeaS G3 RMS\nDemand forecast · Price optimisation · LOS restrictions"]
    DUETTO["Duetto\nOpen Pricing · Group evaluation · Displacement"]
    REVMGR["Revenue Manager\nHuman override · Strategy approval"]
    IDEAS2  -->|"rate recommendations"| REVMGR
    DUETTO  -->|"group strategy"| REVMGR
  end

  subgraph CRS2["🔵 Central Distribution Hub"]
